# Server-side only — proxied via /api/agent/chat. Never set the VITE_ variant.
ANTHROPIC_API_KEY=sk-ant-...

# Browser-safe — Supabase publishable anon key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Vercel Blob base URLs. Leave unset for local dev to fall back to /pdfs and
# /pdfs-rendered (served by the symlinks into ../Anatom3d/).
VITE_PDFS_BASE_URL=https://<store>.public.blob.vercel-storage.com/pdfs
VITE_PDFS_RENDERED_BASE_URL=https://<store>.public.blob.vercel-storage.com/pdfs-rendered

# Local-only — used by tools/upload_to_blob.ts. Not needed at runtime.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
