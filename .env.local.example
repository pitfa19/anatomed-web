# Server-side only - proxied via /api/agent/chat. Never set the VITE_ variant.
ANTHROPIC_API_KEY=sk-ant-...

# Browser-safe - Supabase publishable anon key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Public Supabase Storage URLs for the 5 bundled PDFs and their rendered pages.
# Leave unset to fall back to /pdfs and /pdfs-rendered (local dev only).
VITE_PDFS_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/pdfs
VITE_PDFS_RENDERED_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/pdfs-rendered

# Public bucket for part thumbnails (rendered by tools/render_part_thumbnails.py).
# Leave unset to serve from /models/thumbs locally.
VITE_THUMBS_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/thumbs

# Local-only - used by tools/upload_to_supabase.ts to push the bundled assets
# to Supabase Storage. Pull from Supabase Dashboard → Settings → API → service_role.
# Never commit this; never ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
